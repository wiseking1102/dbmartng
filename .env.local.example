# ─── DBMartNG — Environment Variables ───────────────────────
# Copy this file to .env.local and fill in your values.
# For Vercel: add each variable in Project Settings → Environment Variables.

# ═══════════════════════════════════════════════════════════════
# SUPABASE — Database & Authentication
# ═══════════════════════════════════════════════════════════════
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ═══════════════════════════════════════════════════════════════
# PAYSTACK — Nigerian Payments
# ═══════════════════════════════════════════════════════════════
# Get these from: Paystack Dashboard → Settings → API Keys & Webhooks
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

# ═══════════════════════════════════════════════════════════════
# GOOGLE GEMINI — AI Chat Assistant
# ═══════════════════════════════════════════════════════════════
# Get from: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=your-gemini-api-key

# ═══════════════════════════════════════════════════════════════
# RESEND — Transactional Email
# ═══════════════════════════════════════════════════════════════
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# ═══════════════════════════════════════════════════════════════
# CLOUDFLARE TURNSTILE — CAPTCHA / Bot Protection
# ═══════════════════════════════════════════════════════════════
# Get from: Cloudflare Dashboard → Turnstile → Add Site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxx

# ═══════════════════════════════════════════════════════════════
# TAWK.TO — Live Chat Widget
# ═══════════════════════════════════════════════════════════════
# Get from: Tawk.to Dashboard → Administration → Property Settings
NEXT_PUBLIC_TAWK_PROPERTY_ID=your-tawk-property-id
NEXT_PUBLIC_TAWK_WIDGET_ID=your-tawk-widget-id

# ═══════════════════════════════════════════════════════════════
# SITE URL — Used in email links & SEO metadata
# ═══════════════════════════════════════════════════════════════
NEXT_PUBLIC_SITE_URL=https://dbmart.ng

# ═══════════════════════════════════════════════════════════════
# CRON SECRET — Protects scheduled job endpoints
# ═══════════════════════════════════════════════════════════════
# Set any random string. Must match GITHUB_REPO → Settings → Secrets
CRON_SECRET=your-random-cron-secret-string
